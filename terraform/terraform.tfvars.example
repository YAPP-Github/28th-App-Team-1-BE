# 이 파일을 terraform.tfvars 로 복사한 뒤 실제 값을 채워서 사용하세요.
# terraform.tfvars 는 .gitignore 에 의해 커밋되지 않습니다.

aws_region        = "ap-northeast-2"
aws_profile       = "d14"          # ~/.aws/credentials 의 [d14] 섹션 사용
project_name      = "d14"
environment       = "prod"

# AWS 콘솔에서 미리 생성한 키 페어 이름 (EC2 > Key Pairs)
ec2_key_pair_name = "d14-key"

# SSH 허용 IP (운영시 팀 IP/32로 좁히는 것을 권장)
allowed_ssh_cidr  = "0.0.0.0/0"

# Spot 가격 상한 (USD/hr) — 시세가 이를 초과하면 인스턴스 stop, 떨어지면 자동 재개
# - 서울 t3.micro 평소 시세: ~$0.004/hr (≈ $2.9/월)
# - 0.008 상한: 월 최대 $5.8 캡, 거의 회수 안 됨
spot_max_price    = "0.008"

instance_type     = "t3.micro"
root_volume_size  = 20
